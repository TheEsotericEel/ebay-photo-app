// Copy this file to Secrets.xcconfig (ignored by git) and fill values.
SUPABASE_URL = https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY
SUPABASE_STORAGE_BUCKET = photo-assets
DEVELOPMENT_AUTH_BYPASS = NO
GOOGLE_IOS_CLIENT_ID = YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
GOOGLE_SERVER_CLIENT_ID = YOUR_WEB_SERVER_CLIENT_ID.apps.googleusercontent.com
GOOGLE_REVERSED_CLIENT_ID = com.googleusercontent.apps.YOUR_REVERSED_IOS_CLIENT_ID
